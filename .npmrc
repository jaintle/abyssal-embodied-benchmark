# legacy-peer-deps allows installing packages whose declared peer dependency
# version ranges are stale but runtime-compatible.
#
# Specifically: @react-three/postprocessing@2.x declares
#   peerDependencies: { "@react-three/fiber": "^8.0" }
# but is fully compatible at runtime with fiber@9.x (useThree / useFrame
# APIs are unchanged between v8 and v9).
#
# This file must live at the repo root — npm workspaces ignores .npmrc
# files inside workspace subdirectories.
legacy-peer-deps=true
